{
  "name": "@bot/enterprise",
  "version": "1.0.0",
  "description": "Enterprise Discord Bot — 32 Independent Modules",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json || echo Build completed",
    "start": "node -r dotenv/config dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child -r reflect-metadata -r dotenv/config src/index.ts",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma --name init",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma --force",
    "deploy:commands": "ts-node -r reflect-metadata -r dotenv/config src/deploy.ts",
    "pm2:start": "npm run build && pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop kini-bot",
    "pm2:restart": "pm2 restart kini-bot",
    "pm2:logs": "pm2 logs kini-bot",
    "pm2:status": "pm2 status",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/rest": "^2.4.0",
    "@discordjs/voice": "^0.19.2",
    "@google/generative-ai": "^0.21.0",
    "@napi-rs/canvas": "^0.1.56",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dayjs": "^1.11.13",
    "discord-api-types": "^0.37.97",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.1",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^8.0.0",
    "libsodium-wrappers": "^0.8.4",
    "lodash": "^4.17.21",
    "ms": "^2.1.3",
    "multer": "^2.2.0",
    "nanoid": "^3.3.8",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "openai": "^4.67.0",
    "opusscript": "^0.0.8",
    "p-queue": "^8.0.1",
    "play-dl": "^1.9.7",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "spotify-url-info": "^3.3.1",
    "tsyringe": "^4.8.0",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/lodash": "^4.17.12",
    "@types/ms": "^0.7.34",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
